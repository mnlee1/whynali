# Supabase (실제 값은 .env.local에만 넣고, .env.example은 빈 채로 커밋)
# Project URL 형식: https://프로젝트참조.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site URL (소셜 로그인 리다이렉트용)
# 로컬: http://localhost:3000
# 테스트: https://dev-whynali.vercel.app
# 실서버: https://whynali.vercel.app
NEXT_PUBLIC_SITE_URL=

# Naver (News API + Login)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Groq AI (커뮤니티 매칭, 중복 체크, 급증 감지, 카테고리 분류, 뉴스 연결)
# https://console.groq.com 에서 발급
# 여러 키 사용 시 콤마로 구분 (Rate Limit 회피)
# 예: GROQ_API_KEY=key1,key2,key3
GROQ_API_KEY=

# AI 프로바이더 선택 (groq, perplexity) - 기본 groq
# Perplexity 전환 대비 추상화 레이어 구현
AI_PROVIDER=groq

# Kakao / Google: Supabase 대시보드(Authentication → Providers)에서 설정.
# 앱 .env에는 필수 아님. 로컬에서 Supabase 연동 테스트 시에만 사용할 수 있음.
# NEXT_PUBLIC_KAKAO_CLIENT_ID= (카카오 REST API 키)
# KAKAO_CLIENT_SECRET=
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# 관리자 이메일 (콤마로 구분, 이 이메일로 로그인 시 관리자 버튼 표시 및 /admin 접근 허용)
ADMIN_EMAILS=

# Vercel Cron 인증 (선택)
CRON_SECRET=

# Perplexity API — AI 토론 주제 생성용 (선택)
# 미설정 시 이슈 승인 후 AI 자동 생성 건너뜀 (graceful degradation)
# 설정 시 이슈 메타데이터(제목·카테고리·상태·화력)만 사용. 본문 미사용.
# https://docs.perplexity.ai/ 에서 발급
PERPLEXITY_API_KEY=

# 이슈 후보 자동 생성 임계값 (선택 — 기본값으로 동작, 필요 시 오버라이드)
# CANDIDATE_WINDOW_HOURS=3             # 건수 집계 시간 창 (기본 3시간)
# CANDIDATE_ALERT_THRESHOLD=5          # 대기 등록 임계값 (기본 5건)
# CANDIDATE_AUTO_APPROVE_THRESHOLD=10  # 자동 승인 임계값 (기본 10건)
# CANDIDATE_NO_RESPONSE_HOURS=6        # 자동 승인까지 무대응 허용 시간 (기본 6시간)
# CANDIDATE_MIN_UNIQUE_SOURCES=2       # 대기 등록 최소 고유 출처 수 (기본 2곳)
# CANDIDATE_MIN_HEAT_TO_REGISTER=15    # 이슈 등록 후 화력이 이 값 미만이면 자동 반려 (기본 15점)
# CANDIDATE_COMMUNITY_MATCH_THRESHOLD=2 # 커뮤니티 글 이슈 매칭 최소 공통 키워드 수 (기본 2개)

# AI 기능 ON/OFF (선택 — 기본 false)
# ENABLE_AI_GROUPING=false                  # AI 기반 뉴스 그루핑 (비활성 권장, 느림)
# ENABLE_AI_GROUP_VALIDATION=false          # AI 그룹 검증 (이슈 적합성 판단)
# ENABLE_AI_COMMUNITY_MATCHING=true         # AI 커뮤니티 매칭 (권장: true, Groq 사용)
# ENABLE_AI_DUPLICATE_GROUP_CHECK=true      # AI 중복 그룹 체크 (권장: true, 쪼개진 이슈 자동 병합)
# ENABLE_AI_NEWS_VALIDATION=true            # AI 뉴스 연결 검증 (권장: true, 오연결 방지)

# 카테고리 분류 전략 (선택 — 기본 hybrid)
# CATEGORY_STRATEGY=ai       # AI만 사용 (권장: 유지보수 불필요, Groq 무료 플랜으로 충분)
# CATEGORY_STRATEGY=hybrid   # 하이브리드 (키워드 우선, 신뢰도 낮으면 AI)
# CATEGORY_STRATEGY=keyword  # 키워드만 사용 (AI 비활성화, 유지보수 필요)
# 
# AI 전용 모드 권장 이유:
# - 하루 평균 4개 이슈 × 250토큰 = 1,000토큰 (Groq 무료 플랜의 0.2%)
# - 키워드 유지보수 불필요
# - 맥락 이해로 정확도 향상
# - 새로운 케이스 자동 대응
# 설정: ENABLE_AI_CATEGORY=true + CATEGORY_STRATEGY=ai

# AI 카테고리 분류 활성화 (선택 — 기본 false)
# ENABLE_AI_CATEGORY=true    # AI 카테고리 분류 사용 (CATEGORY_STRATEGY와 함께 사용)

# AI 신뢰도 임계값 (선택)
# AI_COMMUNITY_MATCH_CONFIDENCE=70          # 커뮤니티 AI 매칭 최소 신뢰도 (기본 70%)
# DUPLICATE_CHECK_AI_CONFIDENCE=80          # 중복 체크 AI 최소 신뢰도 (기본 80%)
# DUPLICATE_CHECK_WINDOW_HOURS=1            # 중복 체크 시간 창 (기본 1시간)

# 긴급 이슈 타임아웃 자동 승인 (기본 2시간)
# 연예/정치 카테고리의 화력 높은 대기 이슈를 N시간 후 자동 승인
# URGENT_AUTO_APPROVE_HOURS=2

# 이슈 상태 자동 전환 임계값 (선택 — 기본값으로 동작, 필요 시 오버라이드)
# 규격: 08_이슈상태전환_규격.md
# STATUS_IGNITE_TO_DEBATE_HOURS=6   # 점화→논란중 전환 최소 경과 시간(시) (기본 6시간)
# STATUS_IGNITE_MIN_HEAT=40         # 점화→논란중 전환 최소 화력 (기본 40점)
# STATUS_CLOSED_IDLE_HOURS=48       # 논란중→종결: 신규 수집 공백 기간(시) (기본 48시간)
# STATUS_CLOSED_MAX_HEAT=10         # 종결 판단 화력 임계값 (기본 10점)
