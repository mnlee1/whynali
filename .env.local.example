# 왜난리 환경변수 설정 예시
# .env.local 파일을 생성하고 이 내용을 복사한 후 실제 값으로 변경하세요.

# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===== Cron Secret =====
CRON_SECRET=your-cron-secret

# ===== 네이버 API =====
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# ===== Groq AI (커뮤니티 매칭, 중복 체크, 급증 검증) =====
GROQ_API_KEY=your-groq-api-key

# ===== Perplexity AI (선택 사항, 뉴스 그루핑 품질 개선) =====
# PERPLEXITY_API_KEY=your-perplexity-api-key
# ENABLE_AI_GROUPING=false
# ENABLE_AI_GROUP_VALIDATION=false

# ===== 이슈 후보 생성 임계값 =====
# 최소 뉴스 건수 (기본 5)
CANDIDATE_ALERT_THRESHOLD=5

# 자동 승인 화력 기준 (기본 30)
CANDIDATE_AUTO_APPROVE_THRESHOLD=30

# 최소 등록 화력 (기본 15)
CANDIDATE_MIN_HEAT_TO_REGISTER=15

# 건수 집계 시간 창 (기본 24시간)
CANDIDATE_WINDOW_HOURS=24

# 최소 고유 출처 수 (기본 2)
CANDIDATE_MIN_UNIQUE_SOURCES=2

# 관리자 무대응 시 자동 승인 시간 (기본 6시간)
CANDIDATE_NO_RESPONSE_HOURS=6

# 커뮤니티 매칭 최소 공통 키워드 수 (기본 2)
CANDIDATE_COMMUNITY_MATCH_THRESHOLD=2

# ===== 뉴스 급증 감지 (NEW) =====
# 5분 임계값 (기본 5건)
NEWS_BURST_5MIN_THRESHOLD=5

# 가속도 비율 (기본 0.5 = 50%)
NEWS_BURST_ACCELERATION_RATIO=0.5

# ===== 커뮤니티 급증 감지 (NEW) =====
# 커뮤니티 급증 감지 활성화 (기본 false)
ENABLE_COMMUNITY_BURST=true

# 커뮤니티 급증 임계값 (기본 10건)
COMMUNITY_BURST_THRESHOLD=10

# 커뮤니티 급증 감지 시간 창 (기본 10분)
COMMUNITY_BURST_WINDOW_MINUTES=10

# ===== AI 중복 체크 (NEW) =====
# 중복 판단 신뢰도 (기본 80%)
DUPLICATE_CHECK_AI_CONFIDENCE=80

# 중복 체크 시간 창 (기본 1시간)
DUPLICATE_CHECK_WINDOW_HOURS=1
