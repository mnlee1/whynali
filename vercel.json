{
    "ignoreCommand": "bash -c 'if [ \"$VERCEL_GIT_COMMIT_REF\" != \"main\" ]; then exit 0; fi; if echo \"$VERCEL_GIT_COMMIT_MESSAGE\" | grep -qE \"\\[vercel skip\\]|\\[skip ci\\]|\\[skip deploy\\]\"; then exit 0; fi; CHANGED=$(git diff --name-only HEAD^ HEAD 2>/dev/null); [ -z \"$CHANGED\" ] && exit 0; echo \"$CHANGED\" | grep -qv \"^backups/\" && exit 1 || exit 0'",
    "crons": [
        {
            "path": "/api/cron/collect-community",
            "schedule": "*/5 * * * *"
        },
        {
            "path": "/api/cron/recalculate-heat",
            "schedule": "*/10 * * * *"
        },
        {
            "path": "/api/cron/track-a",
            "schedule": "*/30 * * * *"
        },
        {
            "path": "/api/cron/update-timeline",
            "schedule": "30 * * * *"
        },
        {
            "path": "/api/cron/daily-generate-content",
            "schedule": "15 3 * * *"
        },
        {
            "path": "/api/cron/auto-end-discussions",
            "schedule": "0 * * * *"
        },
        {
            "path": "/api/cron/auto-end-votes",
            "schedule": "0 * * * *"
        },
        {
            "path": "/api/cron/notify-pending-reports",
            "schedule": "0 3 * * *"
        },
        {
            "path": "/api/cron/cleanup-unlinked",
            "schedule": "0 3 * * 0"
        },
        {
            "path": "/api/cron/generate-banned-words",
            "schedule": "0 18 * * 6"
        }
    ],
    "functions": {
        "app/api/cron/**": {
            "maxDuration": 300
        },
        "app/api/admin/discussions/generate/**": {
            "maxDuration": 60
        },
        "app/api/admin/votes/generate/**": {
            "maxDuration": 60
        },
        "app/api/admin/shortform/*/generate/**": {
            "maxDuration": 60
        },
        "app/api/admin/rematch-community/**": {
            "maxDuration": 120
        }
    }
}
