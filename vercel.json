{
    "ignoreCommand": "bash vercel-ignore-build.sh",
    "crons": [
        {
            "path": "/api/cron/collect-community",
            "schedule": "*/5 * * * *"
        },
        {
            "path": "/api/cron/recalculate-heat",
            "schedule": "*/10 * * * *"
        },
        {
            "path": "/api/cron/track-a",
            "schedule": "*/30 * * * *"
        },
        {
            "path": "/api/cron/update-timeline",
            "schedule": "30 * * * *"
        },
        {
            "path": "/api/cron/refresh-manual-issues",
            "schedule": "0 */3 * * *"
        },
        {
            "path": "/api/cron/daily-generate-content",
            "schedule": "15 3 * * *"
        },
        {
            "path": "/api/cron/collect-shortform-stats",
            "schedule": "0 3 * * *"
        },
        {
            "path": "/api/cron/auto-end-discussions",
            "schedule": "0 * * * *"
        },
        {
            "path": "/api/cron/auto-end-votes",
            "schedule": "0 * * * *"
        },
        {
            "path": "/api/cron/notify-pending-reports",
            "schedule": "0 3 * * *"
        },
        {
            "path": "/api/cron/refresh-instagram-token",
            "schedule": "0 18 1 * *"
        },
        {
            "path": "/api/cron/cleanup-unlinked",
            "schedule": "0 3 * * 0"
        },
        {
            "path": "/api/cron/generate-banned-words",
            "schedule": "0 18 * * 6"
        },
        {
            "path": "/api/cron/auto-bot-comment",
            "schedule": "30 1 * * 1"
        },
        {
            "path": "/api/cron/auto-bot-comment",
            "schedule": "0 5 * * 2"
        },
        {
            "path": "/api/cron/auto-bot-comment",
            "schedule": "20 0 * * 3"
        },
        {
            "path": "/api/cron/auto-bot-comment",
            "schedule": "45 7 * * 4"
        },
        {
            "path": "/api/cron/auto-bot-comment",
            "schedule": "10 2 * * 5"
        },
        {
            "path": "/api/cron/auto-bot-comment",
            "schedule": "30 4 * * 6"
        },
        {
            "path": "/api/cron/auto-bot-comment",
            "schedule": "0 11 * * 0"
        }
    ],
    "functions": {
        "app/api/cron/**": {
            "maxDuration": 300
        },
        "app/api/admin/discussions/generate/**": {
            "maxDuration": 60
        },
        "app/api/admin/votes/generate/**": {
            "maxDuration": 60
        },
        "app/api/admin/shortform/*/generate/**": {
            "maxDuration": 60
        },
        "app/api/admin/rematch-community/**": {
            "maxDuration": 120
        }
    }
}
