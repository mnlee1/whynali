{
  "crons": [
    {
      "path": "/api/cron/collect-community",
      "schedule": "* * * * *",
      "description": "커뮤니티 데이터 수집 — 매 1분"
    },
    {
      "path": "/api/cron/recalculate-heat",
      "schedule": "*/10 * * * *",
      "description": "이슈 화력 지수 재계산 — 매 10분"
    },
    {
      "path": "/api/cron/track-a",
      "schedule": "0 * * * *",
      "description": "이슈 트래킹 (수집·분류·중복체크·타임라인) — 매시 0분"
    },
    {
      "path": "/api/cron/update-timeline",
      "schedule": "30 * * * *",
      "description": "타임라인 단계 분류 업데이트 — 매시 30분"
    },
    {
      "path": "/api/cron/daily-generate-content",
      "schedule": "0 3 * * *",
      "description": "토론·투표 일일 자동생성 + 신고 배치 알림 + 숏폼 생성 — 매일 12시 KST"
    },
    {
      "path": "/api/cron/auto-end-discussions",
      "schedule": "0 * * * *",
      "description": "자동 마감 조건 충족 토론 종료 처리 — 매시 0분"
    },
    {
      "path": "/api/cron/auto-end-votes",
      "schedule": "0 * * * *",
      "description": "자동 마감 조건 충족 투표 종료 처리 — 매시 0분"
    },
    {
      "path": "/api/cron/notify-pending-reports",
      "schedule": "0 3 * * *",
      "description": "미처리 신고 관리자 알림 — 매일 12시 KST"
    },
    {
      "path": "/api/cron/cleanup-unlinked",
      "schedule": "0 3 * * 0",
      "description": "이슈 미연결 수집 데이터 정리 — 매주 일요일 12시 KST"
    },
    {
      "path": "/api/cron/generate-banned-words",
      "schedule": "0 18 * * 6",
      "description": "AI 금칙어 자동 생성 — 매주 토요일 03시 KST (UTC 18:00)"
    }
  ],
  "functions": {
    "app/api/cron/**": {
      "maxDuration": 300
    },
    "app/api/admin/discussions/generate/**": {
      "maxDuration": 60
    },
    "app/api/admin/votes/generate/**": {
      "maxDuration": 60
    },
    "app/api/admin/shortform/*/generate/**": {
      "maxDuration": 60
    },
    "app/api/admin/rematch-community/**": {
      "maxDuration": 120
    }
  }
}
